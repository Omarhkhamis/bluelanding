generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model admin_users {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("admin")
  avatar_url    String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
}

model custom_codes {
  id         Int      @id @default(autoincrement())
  name       String
  placement  String
  code       String
  is_active  Boolean  @default(true)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  site_key   String   @default("hollywood-smile")
}

model footer_settings {
  locale         String
  logo_url       String?
  phone          String?
  email          String?
  address        String?
  copyright_text String?
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  site_key       String   @default("hollywood-smile")

  @@unique([site_key, locale], map: "footer_settings_site_locale_idx")
}

model form_submissions {
  id           Int      @id @default(autoincrement())
  locale       String   @default("en")
  source       String   @default("website")
  form_name    String?
  page         String?
  full_name    String
  phone        String
  email        String?
  message      String?
  payload_json Json?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  site_key     String   @default("hollywood-smile")
}

model locales {
  code       String   @id
  label      String
  direction  String   @default("ltr")
  is_default Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model media_assets {
  id            Int      @id @default(autoincrement())
  file_name     String
  original_name String
  url           String
  mime_type     String
  size_bytes    Int      @default(0)
  alt_text      String?
  category      String   @default("library")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  site_key      String   @default("hollywood-smile")

  @@unique([site_key, file_name], map: "media_assets_site_file_name_idx")
}

model pages {
  id         Int      @id @default(autoincrement())
  page_key   String
  locale     String   @default("en")
  title      String
  content    String
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  site_key   String   @default("hollywood-smile")

  @@unique([site_key, page_key, locale], map: "pages_site_page_key_locale_idx")
}

model section_items {
  id            Int      @id @default(autoincrement())
  section_key   String
  locale        String   @default("en")
  item_type     String   @default("default")
  title         String?
  subtitle      String?
  description   String?
  image_url     String?
  video_url     String?
  link_url      String?
  alt_text      String?
  sort_order    Int      @default(0)
  is_active     Boolean  @default(true)
  settings_json Json?
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  site_key      String   @default("hollywood-smile")
}

model sections {
  id            Int      @id @default(autoincrement())
  section_key   String
  locale        String   @default("en")
  name          String
  section_type  String
  sort_order    Int      @default(0)
  is_active     Boolean  @default(true)
  heading       String?
  subheading    String?
  description   String?
  button_label  String?
  button_url    String?
  image_url     String?
  settings_json Json?
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  site_key      String   @default("hollywood-smile")

  @@unique([site_key, section_key, locale], map: "sections_site_section_key_locale_idx")
}

model seo_settings {
  locale           String
  meta_title       String?
  meta_description String?
  meta_keywords    String?
  og_image_url     String?
  robots           String?
  canonical_url    String?
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  site_key         String   @default("hollywood-smile")

  @@unique([site_key, locale], map: "seo_settings_site_locale_idx")
}

model site_settings {
  locale           String
  site_name        String
  site_title       String
  site_description String?
  logo_url         String?
  favicon_url      String?
  whatsapp_url     String
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  site_key         String   @default("hollywood-smile")

  @@unique([site_key, locale], map: "site_settings_site_locale_idx")
}

model social_links {
  id         Int    @id @default(autoincrement())
  locale     String
  platform   String
  label      String
  url        String
  sort_order Int    @default(0)
  site_key   String @default("hollywood-smile")
}

model spin_submissions {
  id           Int      @id @default(autoincrement())
  locale       String   @default("en")
  source       String   @default("lucky-spin")
  page         String?
  full_name    String
  phone        String
  prize        String   @default("")
  payload_json Json?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  site_key     String   @default("hollywood-smile")
}
